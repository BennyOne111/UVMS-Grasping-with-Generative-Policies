<launch>
  <!--
    Package-local B5d' wrapper.

    The upstream rexrov_moveit_revised/move_group_revised.launch currently has
    its planning_context_revised.launch include commented out. Without the
    semantic description, /compute_ik exists but MoveIt rejects group "arm_l".

    This wrapper loads the revised semantic/planning context first, then starts
    the original move_group launch. It does not overwrite /robot_description by
    default, so it can be used with the UVMS Gazebo launch that already provides
    the live robot description.
  -->

  <arg name="debug" default="false"/>
  <arg name="info" default="$(arg debug)"/>
  <arg name="pipeline" default="ompl"/>
  <arg name="allow_trajectory_execution" default="false"/>
  <arg name="moveit_controller_manager" default="simple"/>
  <arg name="fake_execution_type" default="interpolate"/>
  <arg name="max_safe_path_cost" default="1"/>
  <arg name="publish_monitored_planning_scene" default="true"/>
  <arg name="capabilities" default=""/>
  <arg name="disable_capabilities" default=""/>
  <arg name="load_robot_description" default="false"/>

  <include file="$(find rexrov_moveit_revised)/launch/planning_context_revised.launch">
    <arg name="load_robot_description" value="$(arg load_robot_description)"/>
  </include>

  <include file="$(find rexrov_moveit_revised)/launch/move_group_revised.launch">
    <arg name="debug" value="$(arg debug)"/>
    <arg name="info" value="$(arg info)"/>
    <arg name="pipeline" value="$(arg pipeline)"/>
    <arg name="allow_trajectory_execution" value="$(arg allow_trajectory_execution)"/>
    <arg name="moveit_controller_manager" value="$(arg moveit_controller_manager)"/>
    <arg name="fake_execution_type" value="$(arg fake_execution_type)"/>
    <arg name="max_safe_path_cost" value="$(arg max_safe_path_cost)"/>
    <arg name="publish_monitored_planning_scene" value="$(arg publish_monitored_planning_scene)"/>
    <arg name="capabilities" value="$(arg capabilities)"/>
    <arg name="disable_capabilities" value="$(arg disable_capabilities)"/>
    <arg name="load_robot_description" value="$(arg load_robot_description)"/>
  </include>
</launch>
