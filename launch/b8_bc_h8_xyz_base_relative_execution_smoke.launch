<launch>
  <arg name="config" default="$(find rexrov_single_oberon7_fm_dp)/config/b8_bc_h8_xyz_base_relative_execution_smoke.yaml" />
  <arg name="checkpoint" default="" />
  <arg name="method_name" default="bc" />
  <arg name="policy_type" default="auto" />
  <arg name="device" default="auto" />
  <arg name="num_inference_steps" default="50" />
  <arg name="ode_steps" default="50" />
  <arg name="rate_hz" default="3.0" />
  <arg name="max_duration_sec" default="7.2" />
  <arg name="max_control_ticks" default="3" />
  <arg name="early_stop_on_reaching" default="false" />
  <arg name="early_stop_distance" default="0.095" />
  <arg name="early_stop_min_control_ticks" default="1" />
  <arg name="early_stop_min_distance_reduction" default="0.0" />
  <arg name="early_stop_initial_distance_override" default="-1.0" />
  <arg name="replan_every_steps" default="1" />
  <arg name="execute_actions" default="false" />
  <arg name="i_understand_this_publishes_arm_commands" default="false" />
  <arg name="output_json" default="$(find rexrov_single_oberon7_fm_dp)/outputs/logs/b8_rollout_planning/bc_h8_xyz_base_relative_execution_smoke_latest.json" />

  <node pkg="rexrov_single_oberon7_fm_dp"
        type="b8_bc_h8_xyz_base_relative_execution_smoke_node.py"
        name="b8_bc_h8_xyz_base_relative_execution_smoke_node"
        output="screen">
    <param name="config" value="$(arg config)" />
    <param name="checkpoint" value="$(arg checkpoint)" />
    <param name="method_name" value="$(arg method_name)" />
    <param name="policy_type" value="$(arg policy_type)" />
    <param name="device" value="$(arg device)" />
    <param name="num_inference_steps" value="$(arg num_inference_steps)" />
    <param name="ode_steps" value="$(arg ode_steps)" />
    <param name="rate_hz" value="$(arg rate_hz)" />
    <param name="max_duration_sec" value="$(arg max_duration_sec)" />
    <param name="max_control_ticks" value="$(arg max_control_ticks)" />
    <param name="early_stop_on_reaching" value="$(arg early_stop_on_reaching)" />
    <param name="early_stop_distance" value="$(arg early_stop_distance)" />
    <param name="early_stop_min_control_ticks" value="$(arg early_stop_min_control_ticks)" />
    <param name="early_stop_min_distance_reduction" value="$(arg early_stop_min_distance_reduction)" />
    <param name="early_stop_initial_distance_override" value="$(arg early_stop_initial_distance_override)" />
    <param name="replan_every_steps" value="$(arg replan_every_steps)" />
    <param name="execute_actions" value="$(arg execute_actions)" />
    <param name="i_understand_this_publishes_arm_commands" value="$(arg i_understand_this_publishes_arm_commands)" />
    <param name="output_json" value="$(arg output_json)" />
  </node>
</launch>
