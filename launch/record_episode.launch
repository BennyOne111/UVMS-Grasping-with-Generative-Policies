<launch>
  <arg name="output_dir" default="/home/benny/uuv_manipulator_ws/src/uvms/rexrov_single_oberon7_fm_dp/data/raw"/>
  <arg name="episode_id" default=""/>
  <arg name="rate_hz" default="10.0"/>
  <arg name="max_duration_sec" default="5.0"/>
  <arg name="success" default="false"/>
  <arg name="require_target" default="false"/>
  <arg name="target_model_name" default="cylinder_target"/>
  <arg name="controller_type" default="unknown"/>

  <rosparam command="load" file="$(find rexrov_single_oberon7_fm_dp)/config/data_collection.yaml" ns="dp_fm/data_collection"/>
  <rosparam command="load" file="$(find rexrov_single_oberon7_fm_dp)/config/topics.yaml" ns="dp_fm/topics"/>
  <rosparam command="load" file="$(find rexrov_single_oberon7_fm_dp)/config/task_grasp.yaml" ns="dp_fm/task"/>
  <rosparam command="load" file="$(find rexrov_single_oberon7_fm_dp)/config/active_joints_left_arm.yaml" ns="dp_fm/active_joints"/>

  <node pkg="rexrov_single_oberon7_fm_dp"
        type="dp_fm_episode_recorder.py"
        name="dp_fm_episode_recorder"
        output="screen">
    <param name="output_dir" value="$(arg output_dir)"/>
    <param name="episode_id" value="$(arg episode_id)"/>
    <param name="rate_hz" value="$(arg rate_hz)"/>
    <param name="max_duration_sec" value="$(arg max_duration_sec)"/>
    <param name="success" value="$(arg success)"/>
    <param name="require_target" value="$(arg require_target)"/>
    <param name="target_model_name" value="$(arg target_model_name)"/>
    <param name="controller_type" value="$(arg controller_type)"/>
  </node>
</launch>
